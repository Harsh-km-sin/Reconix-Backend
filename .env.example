# Auth (JWT) - use a long random string in production
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Optional: bootstrap first admin (run `npm run db:seed` after migrations)
# FIRST_ADMIN_EMAIL=admin@example.com
# FIRST_ADMIN_PASSWORD=your-secure-password
# SEED_XERO_TENANT_ID=seed-tenant-1
